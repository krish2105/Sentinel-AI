# ------------------------------------------------------------------
# Sentinel AI — backend environment. Copy to .env and fill in.
# EVERYTHING here is optional: with no keys the app runs on the
# deterministic mock engine + heuristic ML + SQLite. Zero bill.
# ------------------------------------------------------------------

# App
ENVIRONMENT=development
DEBUG=true

# Database
# Local SQLite (default, zero-setup):
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db
# docker-compose Postgres+pgvector:
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
# Supabase (free tier) — use the connection pooler URL:
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# Secret encryption at rest (Fernet) for live-target endpoint headers / API keys.
# Blank => derived from JWT_SECRET. Set a dedicated random value in production.
HEADER_ENCRYPTION_KEY=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security middleware
# Allowed Host header values (comma-separated). "*" disables the check (local dev).
# In production set to your real hostnames, e.g. sentinel-api.onrender.com
TRUSTED_HOSTS=*
MAX_REQUEST_BYTES=1000000
SECURITY_HEADERS_ENABLED=true

# LLM providers (optional — leave blank to use the mock engine)
# Free Groq key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Or fully offline via Ollama:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
FORCE_MOCK_LLM=false

# ML — turn on real transformers/sentence-transformers (needs requirements-ml.txt)
ENABLE_HEAVY_ML=false
INJECTION_THRESHOLD=0.5
PROXY_BLOCK_THRESHOLD=0.5

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
